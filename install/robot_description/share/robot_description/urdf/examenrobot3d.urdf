<robot name="robot_A">

  <!-- BASE -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- LINK 1 (vertical 2L = 3) -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 1.5"/>
      <geometry>
        <cylinder length="3" radius="0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="joint1" type="revolute">
    <origin xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/> <!-- rotación vertical -->
    <limit lower="-3.14" upper="3.14" effort="1" velocity="1"/>
  </joint>

  <!-- LINK 2 (horizontal L = 1.5) -->
  <link name="link2">
    <visual>
      <origin xyz="0.75 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="1.5" radius="0.05"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="joint2" type="revolute">
    <origin xyz="0 0 3"/> <!-- arriba de la columna -->
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 1 0"/> <!-- pitch -->
    <limit lower="-1.57" upper="1.57" effort="1" velocity="1"/>
  </joint>

  <!-- LINK 3 (horizontal L = 1.5) -->
  <link name="link3">
    <visual>
      <origin xyz="0.75 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="1.5" radius="0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="joint3" type="revolute">
    <origin xyz="1.5 0 0"/>
    <parent link="link2"/>
    <child link="link3"/>
    <axis xyz="0 1 0"/> <!-- pitch -->
    <limit lower="-1.57" upper="1.57" effort="1" velocity="1"/>
  </joint>

</robot>