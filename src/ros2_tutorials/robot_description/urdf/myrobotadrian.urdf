<?xml version="1.0"?>
<robot name="enderman_robot">

  <!-- TORSO -->
  <link name="torso">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.8"/>
      </geometry>
    </visual>
  </link>

  <!-- HEAD -->
  <link name="head">
    <visual>
      <geometry>
        <box size="0.35 0.35 0.35"/>
      </geometry>
      <origin xyz="0 0 0.175"/>
    </visual>
  </link>

  <!-- HEAD JOINT -->
  <joint name="head_joint" type="revolute">
    <parent link="torso"/>
    <child link="head"/>
    <origin xyz="0 0 0.575"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="1" velocity="1"/>
  </joint>

  <!-- RIGHT ARM -->
  <link name="right_arm">
    <visual>
      <geometry>
        <box size="0.12 0.12 0.9"/>
      </geometry>
      <origin xyz="0 0 -0.45"/>
    </visual>
  </link>

  <joint name="right_arm_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_arm"/>
    <origin xyz="0 -0.25 0.3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="1" velocity="1"/>
  </joint>

  <!-- LEFT ARM -->
  <link name="left_arm">
    <visual>
      <geometry>
        <box size="0.12 0.12 0.9"/>
      </geometry>
      <origin xyz="0 0 -0.45"/>
    </visual>
  </link>

  <joint name="left_arm_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_arm"/>
    <origin xyz="0 0.25 0.3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="1" velocity="1"/>
  </joint>

  <!-- RIGHT LEG -->
  <link name="right_leg">
    <visual>
      <geometry>
        <box size="0.15 0.15 0.9"/>
      </geometry>
      <origin xyz="0 0 -0.45"/>
    </visual>
  </link>

  <joint name="right_leg_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_leg"/>
    <origin xyz="0 -0.12 -0.4"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="1.2" effort="1" velocity="1"/>
  </joint>

  <!-- LEFT LEG -->
  <link name="left_leg">
    <visual>
      <geometry>
        <box size="0.15 0.15 0.9"/>
      </geometry>
      <origin xyz="0 0 -0.45"/>
    </visual>
  </link>

  <joint name="left_leg_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_leg"/>
    <origin xyz="0 0.12 -0.4"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="1.2" effort="1" velocity="1"/>
  </joint>

</robot>