<?xml version="1.0"?>
<robot name="mi_robot">

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.2"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- ================= LINK 1 (columna) ================= -->
  <link name="link1">
    <visual>
      <geometry>
        <cylinder length="2.0" radius="0.1"/>
      </geometry>
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- ================= LINK 2 (brazo 1) ================= -->
  <link name="link2">
    <visual>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <!-- giro para pasar de vertical a horizontal -->
    <origin xyz="0 0 2.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- ================= LINK 3 (brazo 2) ================= -->
  <link name="link3">
    <visual>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="1 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

</robot>